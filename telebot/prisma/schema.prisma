generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

enum ReminderStatus {
    pending
    sent
    cancelled
    completed
}

model User {
    id         BigInt   @id @unique
    username   String?
    createdAt  DateTime @default(now()) @map("created_at")
    modifiedAt DateTime @default(now()) @updatedAt @map("modified_at")

    tasks        Task[]
    chatLogs     ChatLog[]
    reminders    Reminder[]
    documentLogs DocumentLog[]

    @@map("users")
}

model DocumentLog {
    id         Int      @id @default(autoincrement())
    userId     BigInt   @map("user_id")
    fileName   String   @map("file_name")
    fileId     String?  @map("file_id")
    mimeType   String?  @map("mime_type")
    s3Path     String?  @map("s3_path")
    tableName  String?  @map("table_name")
    fastApiRes String?  @map("fastapi_res") @db.Text
    createdAt  DateTime @default(now()) @map("created_at")

    users User @relation(fields: [userId], references: [id])

    @@map("document_logs")
}

model Project {
    id         Int      @id @default(autoincrement())
    name       String   @unique
    createdAt  DateTime @default(now()) @map("created_at")
    modifiedAt DateTime @default(now()) @updatedAt @map("modified_at")

    tasks Task[]

    @@map("projects")
}

model Task {
    id          Int       @id @default(autoincrement())
    taskType    String    @map("task_type") // task, bug, feature
    title       String
    notes       String?   @db.Text
    priority    String    @default("medium") // low, medium, high
    status      String    @default("todo") // todo, doing, done
    dueDate     DateTime? @map("due_date")
    completedAt DateTime? @map("completed_at")
    userId      BigInt    @map("user_id")
    projectId   Int?      @map("project_id")
    createdAt   DateTime  @default(now()) @map("created_at")
    modifiedAt  DateTime  @default(now()) @updatedAt @map("modified_at")

    users    User     @relation(fields: [userId], references: [id])
    projects Project? @relation(fields: [projectId], references: [id])

    @@map("tasks")
}

model ChatLog {
    id        BigInt
    userId    BigInt   @map("user_id")
    body      String?
    lang      String
    createdAt DateTime @map("created_at")

    users User @relation(fields: [userId], references: [id])

    @@id([id, userId])
    @@map("chat_logs")
}

model Database {
    id         Int      @id @default(autoincrement())
    name       String
    dialect    String
    host       String
    port       Int
    username   String
    password   String
    createdAt  DateTime @default(now()) @map("created_at")
    modifiedAt DateTime @default(now()) @updatedAt @map("modified_at")

    @@map("databases")
}

model Reminder {
    id         Int            @id @default(autoincrement())
    userId     BigInt         @map("user_id")
    message    String
    status     ReminderStatus @default(pending)
    remindAt   DateTime?      @map("remind_at")
    isPriority Boolean        @default(false) @map("is_priority")
    createdAt  DateTime       @default(now()) @map("created_at")
    modifiedAt DateTime       @default(now()) @updatedAt @map("modified_at")

    users User @relation(fields: [userId], references: [id])

    @@map("reminders")
}
