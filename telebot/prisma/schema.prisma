generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
}

model User {
    id        BigInt   @id @unique
    username  String?
    createdAt DateTime @default(now()) @map("created_at")

    tasks Task[]
    chats Chat[]

    @@map("users")
}

model Project {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    createdAt DateTime @default(now()) @map("created_at")

    tasks Task[]

    @@map("projects")
}

model Task {
    id          Int       @id @default(autoincrement())
    taskType    String    @map("task_type") // task, bug, feature
    title       String
    notes       String?   @db.Text
    priority    String    @default("medium") // low, medium, high
    status      String    @default("todo") // todo, doing, done
    dueDate     DateTime? @map("due_date")
    completedAt DateTime? @map("completed_at")
    userId      BigInt    @map("user_id")
    projectId   Int?      @map("project_id")
    createdAt   DateTime  @default(now()) @map("created_at")

    users     User       @relation(fields: [userId], references: [id])
    projects  Project?   @relation(fields: [projectId], references: [id])
    reminders Reminder[]

    @@map("tasks")
}

model Reminder {
    id        Int      @id @default(autoincrement())
    remindAt  DateTime @map("remind_at")
    isSent    Boolean  @default(false) @map("is_sent")
    taskId    Int      @map("task_id")
    createdAt DateTime @default(now()) @map("created_at")

    tasks Task @relation(fields: [taskId], references: [id])

    @@map("reminders")
}

model Chat {
    id        BigInt
    userId    BigInt   @map("user_id")
    body      String?
    lang      String
    createdAt DateTime @map("created_at")

    users User @relation(fields: [userId], references: [id])

    @@id([id, userId])
    @@map("chats")
}
